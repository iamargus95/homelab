# Copy this file to vault.yml and encrypt with: ansible-vault encrypt vault.yml
# Decrypt to edit: ansible-vault edit vault.yml

vault_container_password: "changeme"
vault_ts_auth_key: "tskey-auth-xxxxx"
vault_immich_db_password: "changeme-long-random-string"
vault_immich_user: "admin@example.com"
vault_immich_pass: "changeme"

# Hermes Agent
vault_hermes_api_server_key: "changeme-long-random-token"
vault_hermes_model_provider: "nous"
