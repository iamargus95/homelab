all:
  children:
    pve_hosts:
      hosts:
        pve1:
          ansible_host: <PVE1_TAILSCALE_IP>
          ansible_user: root
          zfs_pool: zfs-pve-1
        pve2:
          ansible_host: <PVE2_TAILSCALE_IP>
          ansible_user: root
          zfs_pool: zfs-pve-2
          immich_zfs_pool: zfs-pve-2

    containers:
      vars:
        ansible_connection: community.proxmox.proxmox_pct_remote
        ansible_user: root
      children:
        adguard:
          hosts:
            ct100:
              ansible_host: <PVE1_TAILSCALE_IP>
              proxmox_vmid: 100

        immich:
          hosts:
            ct103:
              ansible_host: <PVE2_TAILSCALE_IP>
              proxmox_vmid: 103

        ollama:
          hosts:
            ct104:
              ansible_host: <PVE1_TAILSCALE_IP>
              proxmox_vmid: 104
